<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="AccountCategoryWiseReport" language="groovy" pageWidth="619" pageHeight="842" columnWidth="579" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ce54d9d7-6c57-43ba-9d36-633e9f9ed951">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="product_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ROWNUM SR_NO,TO_NUMBER(SUBSTR(A.ACCOUNT_CODE,8,14))
    			AC_NO,A.NAME,D.DEPOSITAMOUNT,D.UNITOFPERIOD,
    			D.PERIODOFDEPOSIT,TO_CHAR(D.MATURITYDATE,'DD/MM/YYYY')MATURITY_D,D.MATURITYVALUE,D.INTERESTRATE,
    			FN_GET_CATEGORY_NAME(A.ACCOUNT_CODE) CATEGORY_NAME,
    			FN_GET_BALANCE_ASON(TO_DATE($P{as_on_date}),A.ACCOUNT_CODE)
    			BALANCE_AMT
    			FROM ACCOUNT.ACCOUNT A,ACCOUNT.ACCOUNTDEPOSIT D
    			WHERE
       A.ACCOUNT_CODE=D.ACCOUNT_CODE
    			AND SUBSTR(A.ACCOUNT_CODE,1,4)=$P{branch_code}
    			AND FN_GET_BALANCE_ASON(TO_DATE($P{as_on_date}),A.ACCOUNT_CODE)<>0
    			AND SUBSTR(A.ACCOUNT_CODE,5,3)=$P{product_code}]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="AC_NO" class="java.math.BigDecimal"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="DEPOSITAMOUNT" class="java.math.BigDecimal"/>
	<field name="UNITOFPERIOD" class="java.lang.String"/>
	<field name="PERIODOFDEPOSIT" class="java.math.BigDecimal"/>
	<field name="MATURITY_D" class="java.lang.String"/>
	<field name="MATURITYVALUE" class="java.math.BigDecimal"/>
	<field name="INTERESTRATE" class="java.math.BigDecimal"/>
	<field name="CATEGORY_NAME" class="java.lang.String"/>
	<field name="BALANCE_AMT" class="java.math.BigDecimal"/>
	<variable name="TOTAL_BAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE_AMT}]]></variableExpression>
	</variable>
