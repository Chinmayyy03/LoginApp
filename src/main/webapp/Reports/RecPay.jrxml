	<queryString>
		<![CDATA[SELECT
    T.TXN_NUMBER,
    T.ACCOUNT_CODE,
    TRIM(INITCAP(A.NAME)) AS NAME,

    NVL((CASE
            WHEN T.TRANSACTIONINDICATOR_CODE = 'TRCR' THEN AMOUNT
        END), 0) AS CREDITAMOUNT,

    NVL((CASE
            WHEN T.TRANSACTIONINDICATOR_CODE = 'TRDR' THEN AMOUNT
        END), 0) AS DEBITAMOUNT

FROM
    TRANSACTION.TRANSACTION_HT_VIEW T,
    ACCOUNT.ACCOUNT A

WHERE
        T.ACCOUNT_CODE = A.ACCOUNT_CODE
    AND T.BRANCH_CODE =$P{branch_code}
    AND T.TXN_DATE = $P{as_on_date}
    AND T.TRANSACTIONINDICATOR_CODE IN ('TRCR', 'TRDR')

ORDER BY
    T.ACCOUNT_CODE]]>
	</queryString>
	<field name="TXN_NUMBER" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="CREDITAMOUNT" class="java.math.BigDecimal"/>
	<field name="DEBITAMOUNT" class="java.math.BigDecimal"/>
