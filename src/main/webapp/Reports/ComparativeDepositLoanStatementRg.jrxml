<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ComparativeDepositLoanStatementRg" language="groovy" pageWidth="926" pageHeight="595" orientation="Landscape" columnWidth="886" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b5f6da99-ca10-4837-a369-6e4201e6b40d">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ROWNUM AS SR_NO,
    product_code || '   ' || DESCRIPTION AS product_name,
    ACCOUNT_NO1,
    ROUND(AMOUNT_FIRST, 2) AS AMOUNT_FIRST,
    ACCOUNT_NO2,
    ROUND(AMOUNT_SECOND, 2) AS AMOUNT_SECOND,
    ABS(ACT_TOT) AS ACT_TOT,
    ROUND(Amount_Total, 2) AS Amount_Total,
    CASE
        WHEN Amount_Total > 0 THEN 'Inc'
        WHEN Amount_Total = 0 THEN 'No Change'
        ELSE 'Dec'
    END AS INCRDECR
FROM (
    SELECT
        HEADOFFICE.product_code AS product_code,
        HEADOFFICE.DESCRIPTION AS DESCRIPTION,
        ACCOUNT_NO1,
        AMOUNT_FIRST,
        ACCOUNT_NO2,
        AMOUNT_SECOND,
        (ACCOUNT_NO2 - ACCOUNT_NO1) AS ACT_TOT,
        (AMOUNT_SECOND - AMOUNT_FIRST) AS Amount_Total
    FROM
        headoffice.product HEADOFFICE,
        (
            SELECT
                p.product_code AS product_code1,
                COUNT(A.ACCOUNT_CODE) AS ACCOUNT_NO1,
                SUM(
                    NVL(
                        FN_GET_BALANCE_ASON(
                            TO_DATE($P{from_date}, 'DD/MM/YYYY'),
                            A.ACCOUNT_CODE
                        ),
                        0
                    )
                ) AS AMOUNT_FIRST
            FROM
                ACCOUNT.ACCOUNT A,
                headoffice.product P
            WHERE
                SUBSTR(A.ACCOUNT_CODE, 1, 4) = $P{branch_code}
              AND p.product_code = SUBSTR(ACCOUNT_CODE, 5, 3)
                AND
               P.ACCOUNT_TYPE IN ('SB', 'TD', 'PG', 'CA')
           GROUP BY
              p.product_code
        ) DEPOSIT_ACCOUNT1,
        (
            SELECT
                p.product_code AS product_code2,
                COUNT(A.ACCOUNT_CODE) AS ACCOUNT_NO2,
                SUM(
                    NVL(
                        FN_GET_BALANCE_ASON(
                            TO_DATE($P{to_date}, 'DD/MM/YYYY'),
                            A.ACCOUNT_CODE
                        ),
                        0
                    )
                ) AS AMOUNT_SECOND
            FROM
                ACCOUNT.ACCOUNT A,
                headoffice.product P
            WHERE
               SUBSTR(A.ACCOUNT_CODE, 1, 4) = $P{branch_code}
               AND p.product_code = SUBSTR(ACCOUNT_CODE, 5, 3)
               AND
                P.ACCOUNT_TYPE IN ('SB', 'TD', 'PG', 'CA')
                AND FN_GET_BALANCE_ASON(
                        TO_DATE($P{to_date}, 'DD/MM/YYYY'),
                        A.ACCOUNT_CODE
                    ) <> 0
           GROUP BY
              p.product_code
        ) DEPOSIT_ACCOUNT2
  WHERE
        HEADOFFICE.product_code = DEPOSIT_ACCOUNT1.product_code1
       AND HEADOFFICE.product_code = DEPOSIT_ACCOUNT2.product_code2
   ORDER BY
  HEADOFFICE.product_code
)
ORDER BY
    SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="PRODUCT_NAME" class="java.lang.String"/>
	<field name="ACCOUNT_NO1" class="java.math.BigDecimal"/>
	<field name="AMOUNT_FIRST" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_NO2" class="java.math.BigDecimal"/>
