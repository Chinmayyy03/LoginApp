	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="product_code_filter" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT SRNO,ACCOUNT_NO,AC_NAME,DESCRIPTION,product_code,BALANCE_AMT,(PAYBALE_AMT *(-1)) PAYBALE_AMT,Blank
FROM (
					 SELECT row_number() over (partition by product_code order by A.ACCOUNT_CODE) AS SRNO ,
           A.ACCOUNT_CODE ACCOUNT_NO,
           A.NAME AC_NAME,
           P.DESCRIPTION DESCRIPTION,
           p.product_code product_code,
           FN_GET_BALANCE_ASON($P{as_on_date},A.ACCOUNT_CODE)  BALANCE_AMT,
           FN_GET_RECPAY_REPORTS($P{as_on_date},A.ACCOUNT_CODE,'N') PAYBALE_AMT,
          ' ' As Blank

FROM  ACCOUNT.ACCOUNT A,
     ACCOUNT.ACCOUNTDEPOSIT D,
     headoffice.product P

WHERE
      A.ACCOUNT_CODE=D.ACCOUNT_CODE
      AND SUBSTR(A.ACCOUNT_CODE,5,3)=P.PRODUCT_CODE
      AND D.ACCOUNT_CODE LIKE $P{product_code_filter}

      AND SUBSTR(A.ACCOUNT_CODE,1,4)=  $P{branch_code}
      AND FN_GET_BALANCE_ASON($P{as_on_date},A.ACCOUNT_CODE)<>0
      AND  ((A.DATEACCOUNTOPEN IS NULL OR A.DATEACCOUNTOPEN<=$P{as_on_date}))
      AND ((A.DATEACCOUNTCLOSE IS NULL OR A.DATEACCOUNTCLOSE>$P{as_on_date}))
) TEPM
WHERE (BALANCE_AMT<>0 OR PAYBALE_AMT<>0)]]>
	</queryString>
	<field name="SRNO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_NO" class="java.lang.String"/>
	<field name="AC_NAME" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="PRODUCT_CODE" class="java.lang.String"/>
	<field name="BALANCE_AMT" class="java.math.BigDecimal"/>
	<field name="PAYBALE_AMT" class="java.math.BigDecimal"/>
	<field name="BLANK" class="java.lang.String"/>
	<variable name="ledger_sum" class="java.math.BigDecimal" resetType="Group" resetGroup="product code" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE_AMT}]]></variableExpression>
	</variable>
	<variable name="payable_sum" class="java.math.BigDecimal" resetType="Group" resetGroup="product code" calculation="Sum">
		<variableExpression><![CDATA[$F{PAYBALE_AMT}]]></variableExpression>
	</variable>
