	<queryString>
		<![CDATA[select p, description, slab, noac, total, ainner
from(
  select (a.amount_from || ' To ' || a.amount_to) as slab,
  count(b.account_code)||'  ' as noac, sum(b.balance) as total ,
  substr(account_code, 5, 3) p,b. ainner
from BANKDATA.SIZEWISEAMOUNT a, BANKDATA.SIZEWISE b
  where b.branch_code = '$P!{branch_code}'
and b.balance>=a.amount_from
 and  b.balance<=a.amount_to
  group by (a.amount_from || ' To ' || a.amount_to) , b.ainner, substr(account_code, 5, 3)
 ) , headoffice.product
  where p = product_code
 order by p, ainner]]>
	</queryString>
	<field name="P" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="SLAB" class="java.lang.String"/>
	<field name="NOAC" class="java.lang.String"/>
	<field name="TOTAL" class="java.math.BigDecimal"/>
	<field name="AINNER" class="java.lang.String"/>
	<variable name="TOTAL_NOAC" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[new Integer($F{NOAC}.trim())]]></variableExpression>
	</variable>
	<variable name="TOTAL_AMOUNT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
	</variable>
