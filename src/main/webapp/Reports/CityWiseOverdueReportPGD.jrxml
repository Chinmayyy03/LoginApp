<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CityWiseOverdueReport" language="groovy" pageWidth="1080" pageHeight="864" orientation="Landscape" columnWidth="1040" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ef5299e3-33dd-4873-94ad-20c8ee05f514">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="5"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="product_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_product" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_product" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT * FROM (
SELECT DISTINCT T.ACCOUNT_CODE  ACCOUNT_CODE, SUBSTR(T.ACCOUNT_CODE, 5, 3) PRODUCT_CODE,
AA.NAME NAME, FN_CAL_TL_INT_VIR(T.ACCOUNT_CODE,to_date($P{as_on_date},'dd/mm/yyyy')+1 )  ovd_int,
FN_CAL_TL_INT_PENAL (AA.ACCOUNT_CODE ,$P{as_on_date}) penal_int,
FN_GET_BRANCHSUBAREA_NAME(AA.ACCOUNT_CODE) CITY_DESCR,
(SELECT DESCRIPTION FROM HEADOFFICE.PRODUCT
WHERE PRODUCT_CODE = SUBSTR(T.ACCOUNT_CODE, 5, 3) ) PRODUCT_DESCR,
TO_CHAR(AA.DATEACCOUNTOPEN, 'DD/MM/YYYY') OPEN_D,
TO_CHAR(TL.ACCOUNTREVIEWDATE, 'DD/MM/YYYY') REVIEW_D,
TL.SANCTIONAMOUNT SANCTIONAMOUNT,  TL.INSTALLMENTAMOUNT INSTALLMENTAMOUNT,
TO_CHAR(AA.DATEACCOUNTCLOSE, 'DD/MM/YYYY') CLOSE_D,
T.LEDGER_BALANCE  LEADGER_BALANCE,
T.OVERDUE_BALANCE OVERDUE_BALANCE,abs(T.REC_INT)  REC_INT,
DECODE(T.LOANRULE_ID, 1, ROUND(MONTHS_BETWEEN($P{as_on_date},  TL.ACCOUNTREVIEWDATE), 2),
ROUND((T.OVERDUE_BALANCE / DECODE(TL.INSTALLMENTAMOUNT, 0, 1, TL.INSTALLMENTAMOUNT) ), 2)) OVERDUE_MONTHS,
 (TRIM(CC.ADDRESS1) ||' '||TRIM(CC.ADDRESS2) ||' '||TRIM(CC.ADDRESS3)) ADDRESS,
 DECODE((CC.PHONERESIDENCE ||'/'|| NVL(CC.PHONEMOBILE, 0)), '0/0', '0',
 (CC.PHONERESIDENCE ||'/'|| NVL(CC.PHONEMOBILE, 0)))PHONE_NO,
 Fn_Get_Guarantor_Name(1,AA.ACCOUNT_CODE) GAU_NAME_1,
 Fn_Get_Guarantor_Name(2,AA.ACCOUNT_CODE)GAU_NAME_2
 FROM ( SELECT ACCOUNT_CODE ,
 SUM(LEDGER_BALANCE) LEDGER_BALANCE,SUM(OVERDUE_BALANCE) OVERDUE_BALANCE,
 SUM(REC_INT) REC_INT, LOANRULE_ID FROM
 (SELECT A.ACCOUNT_CODE ACCOUNT_CODE, LOANRULE_ID,
 FN_GET_BALANCE_ASON ($P{as_on_date},A.ACCOUNT_CODE) LEDGER_BALANCE,
 OVERDUEONINSTALLMENTRULE(A.ACCOUNT_CODE, $P{as_on_date}, 'N', 0) OVERDUE_BALANCE,
 (FN_GET_RECPAY_ASON($P{as_on_date}, A.ACCOUNT_CODE,'N') +
 FN_GET_RECPAY_ASON($P{as_on_date}, A.ACCOUNT_CODE, 'P')) REC_INT
		FROM ACCOUNT.ACCOUNT A, HEADOFFICE.PRODUCTPARAMETERLOAN P
		WHERE P.PRODUCT_CODE = SUBSTR(A.ACCOUNT_CODE, 5, 3)
		AND SUBSTR(A.ACCOUNT_CODE, 1, 4)  = $P{branch_code}
		AND p.is_application_new_form In ('G','P','D')
		AND P.PRODUCT_CODE between $P{from_product} and $P{to_product} AND 	P.IS_CAL_OVD = 'Y'
		AND A.DATEACCOUNTOPEN <= $P{as_on_date}
		AND (A.DATEACCOUNTCLOSE IS NULL OR A.DATEACCOUNTCLOSE > $P{as_on_date})
	    ORDER BY A.ACCOUNT_CODE)  GROUP BY ACCOUNT_CODE, LOANRULE_ID HAVING SUM(LEDGER_BALANCE) <> 0) T,
		ACCOUNT.ACCOUNTLOAN TL, ACCOUNT.ACCOUNT AA,
		CUSTOMER.CUSTOMER CC
		WHERE TL.ACCOUNT_CODE = T.ACCOUNT_CODE
		AND T.ACCOUNT_CODE = AA.ACCOUNT_CODE
/*		AND T.OVERDUE_BALANCE > 0 */
		AND AA.CUSTOMER_ID = CC.CUSTOMER_ID
		ORDER BY T.ACCOUNT_CODE  )
/*		WHERE OVERDUE_MONTHS <>0 */
		order by CITY_DESCR,ACCOUNT_CODE]]>
	</queryString>
