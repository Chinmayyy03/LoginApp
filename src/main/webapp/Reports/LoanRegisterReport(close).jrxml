	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    A.ACCOUNT_CODE,
    TO_CHAR(A.DATEACCOUNTOPEN, 'DD/MM/YYYY') AS OPEN_D,
    A.NAME,
    NVL(L.DISBURESED_AMOUNT, 0) AS DISBURESED_AMOUNT,
    TO_CHAR(A.DATEACCOUNTCLOSE, 'DD/MM/YYYY') AS CLOSE_D,
    NVL(L.SANCTIONAMOUNT, 0) AS SANCTIONAMOUNT,
    SUBSTR(A.ACCOUNT_CODE, 5, 3) AS PRODUCT,
    HP.DESCRIPTION AS DESCR,
    TO_CHAR(SANCTIONDATE, 'DD/MM/YYYY') AS SANCTION_D,
    TO_CHAR(accountreviewdate, 'DD/MM/YYYY') AS REVIEW_D,
    PERIODOFLOAN,
    FN_GET_LOAN_IR(L.ACCOUNT_CODE, A.DATEACCOUNTOPEN) AS INT_RATE,
    L.RESOLUTIONNUMBER
FROM
    ACCOUNT.ACCOUNT A,
    ACCOUNT.ACCOUNTLOAN L,
    HEADOFFICE.PURPOSE P,
    HEADOFFICE.PRODUCT HP
WHERE
    A.ACCOUNT_CODE = L.ACCOUNT_CODE
    AND SUBSTR(A.ACCOUNT_CODE, 5, 3) = HP.PRODUCT_CODE
    AND P.PURPOSE_ID = L.PURPOSE_ID
    AND SUBSTR(A.ACCOUNT_CODE, 0, 4) = $P{branch_code}
    AND A.DATEACCOUNTCLOSE BETWEEN  $P{as_on_date} AND $P{to_date}
    AND HP.PRODUCT_CODE = $P{product_code}
ORDER BY
    A.ACCOUNT_CODE]]>
	</queryString>
