	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_branch_product%" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    (
        SELECT
            DESCRIPTION
        FROM
            HEADOFFICE.PRODUCT
        WHERE
            PRODUCT_CODE = SUBSTR(A.ACCOUNT_CODE, 5, 3)
    ) AS PRODUCT_DESCR,
    SUBSTR(A.ACCOUNT_CODE, 5, 3) AS PRODUCT_CODE,
    Fn_get_Address_on_name (A.name) Address,
    TO_NUMBER(SUBSTR(A.ACCOUNT_CODE, 8, 7)) AS ACCOUNT_CODE,
    TRIM(A.NAME) AS NAME,
    A.CUSTOMER_ID,
    TRIM(AG.SERIAL_NUMBER || ' ' || INITCAP(AG.NAME)) AS GNAME,
    AG.CUSTOMER_ID AS G_CUSTOMER_ID,
    TO_CHAR(A.DATEACCOUNTOPEN, 'DD/MM/YYYY') AS OPNE_D,
    TO_CHAR(L.ACCOUNTREVIEWDATE, 'DD/MM/YYYY') AS REVIEW_D,
    L.RESOLUTIONNUMBER,
    (
        SELECT
            DESCRIPTION
        FROM
            HEADOFFICE.PURPOSE
        WHERE
            PURPOSE_ID = L.PURPOSE_ID
    ) AS PUR_DESC,
    L.CURRENTINTERESTRATE,
    L.SANCTIONAMOUNT,
    L.INSTALLMENTAMOUNT,
    TO_CHAR(A.DATEACCOUNTCLOSE, 'DD/MM/YYYY') AS CLOSE_D,
    '' AS REMARK
FROM
    ACCOUNT.ACCOUNT A
    JOIN ACCOUNT.ACCOUNTLOAN L
        ON A.ACCOUNT_CODE = L.ACCOUNT_CODE
    JOIN HEADOFFICE.PURPOSE P
        ON P.PURPOSE_ID = L.PURPOSE_ID
    JOIN BALANCE.ACCOUNT B
        ON B.ACCOUNT_CODE = A.ACCOUNT_CODE
    JOIN ACCOUNT.ACCOUNTGUARANTOR AG
        ON AG.ACCOUNT_CODE = A.ACCOUNT_CODE
WHERE
    A.ACCOUNT_CODE LIKE $P{from_branch_product%}
    AND A.DATEACCOUNTOPEN BETWEEN
       $P{as_on_date}
        AND $P{to_date}
ORDER BY  A.ACCOUNT_CODE]]>
	</queryString>
