<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="LoanRegisterReportGuarantor" language="groovy" pageWidth="1056" pageHeight="595" orientation="Landscape" columnWidth="1016" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="74a381c0-e71c-4722-86e0-a05bc449a5f7">
