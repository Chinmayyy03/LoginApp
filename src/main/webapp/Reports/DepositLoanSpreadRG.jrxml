	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    D_BRANCH_CODE,
    DECODE(TRIM(D_SEQ_NO), '999', '', '1000', '', TRIM(D_SEQ_NO)) AS D_SEQ_NO,
    D_DESCRIPTION,
    D_REP_CHAR,
    D_BALANCE,
    L_BRANCH_CODE,
    DECODE(TRIM(L_SEQ_NO), '999', '', '1000', '', TRIM(L_SEQ_NO)) AS L_SEQ_NO,
    L_DESCRIPTION,
    L_REP_CHAR,
    L_BALANCE
FROM
    (
        SELECT
            BRANCH_CODE AS D_BRANCH_CODE,
            SEQ_NO AS D_SEQ_NO,
            DESCRIPTION AS D_DESCRIPTION,
            REP_CHAR AS D_REP_CHAR,
            BALANCE AS D_BALANCE
        FROM
            BANKDATA.FP_TD_TL_AVG
        WHERE
            REP_CHAR = 'D'
            AND SEQ_NO <> 1001
        GROUP BY
            BRANCH_CODE,
            SEQ_NO,
            DESCRIPTION,
            REP_CHAR,
            BALANCE
    ),
    (
        SELECT
            BRANCH_CODE AS L_BRANCH_CODE,
            SEQ_NO AS L_SEQ_NO,
            DESCRIPTION AS L_DESCRIPTION,
            REP_CHAR AS L_REP_CHAR,
            BALANCE AS L_BALANCE
        FROM
            BANKDATA.FP_TD_TL_AVG
        WHERE
            REP_CHAR = 'L'
            AND SEQ_NO <> 1001
        GROUP BY
            BRANCH_CODE,
            SEQ_NO,
            DESCRIPTION,
            REP_CHAR,
            BALANCE
    )
WHERE
    L_SEQ_NO = D_SEQ_NO
ORDER BY
    TO_NUMBER(L_SEQ_NO)]]>
	</queryString>
