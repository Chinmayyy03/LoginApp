<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="BackdatedPayableReceivableRG1" language="groovy" pageWidth="792" pageHeight="612" orientation="Landscape" columnWidth="752" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="18c221e9-4a42-447c-9c00-1bd72f5e4ccd">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="agent_name" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select substr(t.product_code,1,1) schme_code,
t.product_code,fn_get_product_name(t.product_code) name,  abs(sum(t.LEDGERBALANCE)) ledger_bal,
 t.GLACCOUNT_CODE gl_code, G.DESCRIPTION DESCRIPTION,
 abs(Fn_Get_Balance_N ( $P{branch_code}  , t.GLACCOUNT_CODE, $P{as_on_date})) gl_bal
  from BANKDATA.TEMP_BALANCECERTIFICATE_back t , headoffice.glaccount g
 where t.GLACCOUNT_CODE= g.GLACCOUNT_CODE
 and t.branch_code=$P{branch_code} and t.LEDGERBALANCE<>0
 group by t.product_code,t.GLACCOUNT_CODE,G.DESCRIPTION
 order by t.product_code]]>
	</queryString>
	<field name="SCHME_CODE" class="java.lang.String"/>
	<field name="PRODUCT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="LEDGER_BAL" class="java.math.BigDecimal"/>
	<field name="GL_CODE" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="GL_BAL" class="java.math.BigDecimal"/>
	<variable name="totalLedg" class="java.math.BigDecimal" resetType="Group" resetGroup="glcode" calculation="Sum">
		<variableExpression><![CDATA[$F{LEDGER_BAL}]]></variableExpression>
	</variable>
	<variable name="diffbalance" class="java.math.BigDecimal"/>
	<variable name="diffrence" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{GL_BAL}.subtract$V{totalLedg}]]></variableExpression>
	</variable>
