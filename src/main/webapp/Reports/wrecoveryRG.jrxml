		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ACCOUNT_CODE AS ACC_NUMBER,
    NAME AS ACCOUNT_NAME,
    SUBSTR(ACCOUNT_CODE, 5, 3) AS PRODUCT_CODE,
    FN_GET_PRODUCT_NAME(SUBSTR(ACCOUNT_CODE, 5, 3)) AS PRODUCT_NAME,
    ABS(OUT_BALANCE) AS BALANCE,
    CASE
        WHEN IS_STANDARD IN ('Y') THEN OVD_BALANCE
        ELSE 0
    END AS OVD_BALANCE,
    CASE
        WHEN IS_STANDARD IN ('N') THEN OVD_BALANCE
        ELSE 0
    END AS N_P_A_AMOUNT,
    CASE
        WHEN IS_STANDARD IN ('Y') THEN RECOVERY
        ELSE 0
    END AS RECO_NON_N_P_A,
    CASE
        WHEN IS_STANDARD IN ('N') THEN RECOVERY
        ELSE 0
    END AS RECO_N_P_A,
    TOTAL_RECOVERY,
    INTEREST_AMOUNT
FROM
    BANKDATA.WRECOVERY
WHERE
    (RECOVERY > 0 OR OVD_BALANCE > 0)
    AND branch_code = $P{branch_code}
ORDER BY
    ACCOUNT_CODE]]>
	</queryString>
