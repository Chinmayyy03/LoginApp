	<queryString>
		<![CDATA[----------------------- AccountOpenClose2dateRG (Open) --------------------------------
SELECT
    DISTINCT A.ACCOUNT_CODE,
    INITCAP(TRIM(AN.NAME)) AS NOMINEE_NAME,
    SUBSTR(A.ACCOUNT_CODE, 5, 3) AS PRODUCT,
    '1' AS P,
    TO_CHAR(A.DATEACCOUNTCLOSE, 'DD-MON-YY') AS CLOSE_D,
    B.DESCRIPTION,
    INITCAP(TRIM(A.NAME)) AS NAME,
    TO_CHAR(A.DATEACCOUNTOPEN, 'DD-MON-YY') AS OPEN_D,
    LEDGERBALANCE AS BAL
FROM
    ACCOUNT.ACCOUNT A,
    ACCOUNT.ACCOUNTNOMINEE AN,
    HEADOFFICE.PRODUCT B,
    BALANCE.ACCOUNT BA
WHERE
     SUBSTR(A.ACCOUNT_CODE, 5, 3) = B.PRODUCT_CODE
  AND A.DATEACCOUNTOPEN BETWEEN $P{as_on_date} AND $P{to_date}
    AND SUBSTR(A.ACCOUNT_CODE, 1, 4) = $P{branch_code}
   AND A.ACCOUNT_CODE = BA.ACCOUNT_CODE
   AND A.ACCOUNT_CODE = AN.ACCOUNT_CODE(+)
   AND B.ACCOUNT_TYPE = $P{account_type}
    AND B.PRODUCT_CODE BETWEEN $P{from_product} AND $P{to_product}
ORDER BY  PRODUCT, A.ACCOUNT_CODE]]>
	</queryString>
