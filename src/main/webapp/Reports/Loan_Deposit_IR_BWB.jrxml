	<queryString>
		<![CDATA[select t.intrate, t.branch_1 as HEADOFFICE,branch_2 BHEDASGAON
,branch_3 KAPASHI, branch_4 KOKARUD ,
 branch_5 SHAHUWADI,branch_6 MALKAPUR,branch_7 SARUD, branch_8
BAMBAWADE,branch_9 KOLHAPUR,branch_10 ARALE,
 branch_11 VERLE , branch_12 SONDOLI,branch_14 PORLE,branch_15
BAZAR_BHOGAON,branch_16 KARANJFEN,
 branch_21 SHENDGEWADI,branch_22 KOTOLI, branch_23 MUMBAI ,
NVL(T.BRANCH_1,0) + NVL(t.branch_2,0) + NVL(t.branch_3,0) +
NVL(t.branch_4,0) + NVL(t.branch_5,0)
 + NVL(t.branch_6,0) + NVL(t.branch_7,0) + NVL(t.branch_8,0) +
NVL(t.branch_9,0) + NVL(t.branch_10,0) + NVL(t.branch_11,0) +
NVL(t.branch_12,0) + NVL(t.branch_13,0)
 + NVL(t.branch_14,0) + NVL(t.branch_15,0)  + NVL(t.branch_16,0) +
NVL(t.branch_17,0) + NVL(t.branch_18,0)  + NVL(t.branch_19,0) +
NVL(t.branch_20,0) + NVL(t.branch_21,0)
 + NVL(t.branch_22,0) + NVL(t.branch_23,0)
   TOTAL   from bankdata.ratewise_loan t order by t.intrate]]>
	</queryString>
