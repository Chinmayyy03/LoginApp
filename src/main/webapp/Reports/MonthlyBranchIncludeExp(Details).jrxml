<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="MonthlyBranchIncludeExp(Details)" language="groovy" pageWidth="745" pageHeight="595" orientation="Landscape" columnWidth="705" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a50cbbd7-a6f3-45a3-851b-c7e42b8cd5b8">
