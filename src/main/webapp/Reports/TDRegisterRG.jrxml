	<variable name="deposite_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPOSITAMOUNT}]]></variableExpression>
	</variable>
	<variable name="Maturity_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{MATURITYVALUE}]]></variableExpression>
	</variable>
	<variable name="Ledger_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LEDGERBALANCE}]]></variableExpression>
	</variable>
