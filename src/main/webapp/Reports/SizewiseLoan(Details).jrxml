	<queryString>
		<![CDATA[SELECT
    p,
    description,
    slab,
    noac,
    total,
    ainner
FROM (
    SELECT
        (a.amount_from || ' To ' || a.amount_to) AS slab,
         COUNT(b.account_code) AS noac,
        SUM(b.balance) AS total,
        SUBSTR(account_code, 5, 3) AS p,
        b.ainner
    FROM
        BANKDATA.SIZEWISEAMOUNT_LOAN a,
        BANKDATA.SIZEWISE_LOAN b
    WHERE
        b.branch_code = '$P!{branch_code}'
        AND a.product_code = b.ainner
    GROUP BY
        (a.amount_from || ' To ' || a.amount_to),
        b.ainner,
        SUBSTR(account_code, 5, 3)
),
headoffice.product
WHERE
    p = product_code
ORDER BY
    p,
    ainner]]>
	</queryString>
