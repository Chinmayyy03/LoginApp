	<field name="PERIODOFDEPOSIT" class="java.math.BigDecimal"/>
	<field name="B" class="java.lang.String"/>
	<field name="PROCESSFOR_MATURITY" class="java.lang.String"/>
	<field name="A" class="java.lang.String"/>
	<field name="LEDGERBALANCE" class="java.math.BigDecimal"/>
	<field name="INT_DATE" class="java.sql.Timestamp"/>
	<variable name="PRODUCT_COUNT" class="java.lang.Integer" resetType="Group" resetGroup="PRODUCT_GROUP" calculation="Count">
