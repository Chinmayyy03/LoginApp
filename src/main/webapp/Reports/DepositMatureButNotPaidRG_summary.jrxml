	</variable>
	<variable name="SUM_DEPOSITE" class="java.math.BigDecimal" resetType="Group" resetGroup="PRODUCT_GROUP" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPOSITAMOUNT}]]></variableExpression>
	</variable>
	<variable name="SR_NO" class="java.lang.Integer" incrementType="Group" incrementGroup="PRODUCT_GROUP" calculation="Count">
		<variableExpression><![CDATA[new Integer(1)]]></variableExpression>
	</variable>
	<variable name="TOTAL_LEDGER " class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LEDGERBALANCE}]]></variableExpression>
	</variable>
	<variable name="TOTAL_DEPOSIT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DEPOSITAMOUNT}]]></variableExpression>
	</variable>
