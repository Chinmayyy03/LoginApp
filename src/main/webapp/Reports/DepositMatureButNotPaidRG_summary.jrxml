<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ProductCountReport" pageWidth="649" pageHeight="842" columnWidth="609" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="d3def8ff-5cd6-4da2-9677-8c8a52ac9f8c">
