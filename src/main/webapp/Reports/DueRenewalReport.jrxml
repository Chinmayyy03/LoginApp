<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DueRenewalReport" language="groovy" pageWidth="727" pageHeight="842" columnWidth="687" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="165db01b-f4dd-456f-8638-cb2836e796c1">
	<property name="ireport.zoom" value="1.8627639691774651"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="due_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT A.ACCOUNT_CODE, A.NAME, A.DATEACCOUNTOPEN, L.LIMITAMOUNT, P.PRODUCT_CODE,
               L.ACCOUNTREVIEWDATE, L.PERIODOFLOAN, B.LEDGERBALANCE, P.DESCRIPTION
               FROM ACCOUNT.ACCOUNT A, ACCOUNT.ACCOUNTLOAN L, BALANCE.ACCOUNT B, HEADOFFICE.PRODUCT P
               WHERE SUBSTR(A.ACCOUNT_CODE, 0, 4) =  $P{branch_code}
                AND SUBSTR(A.ACCOUNT_CODE, 5, 3) = P.PRODUCT_CODE
                AND A.ACCOUNT_CODE = L.ACCOUNT_CODE
                AND A.ACCOUNT_CODE = B.ACCOUNT_CODE
                AND A.DATEACCOUNTCLOSE IS NULL
                AND L.ACCOUNTREVIEWDATE BETWEEN $P{as_on_date}
                AND $P{due_date}
               GROUP BY P.PRODUCT_CODE, A.ACCOUNT_CODE, A.NAME, A.DATEACCOUNTOPEN, L.LIMITAMOUNT,
                L.ACCOUNTREVIEWDATE, L.PERIODOFLOAN, B.LEDGERBALANCE, P.DESCRIPTION
               ORDER BY P.PRODUCT_CODE, L.ACCOUNTREVIEWDATE]]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="DATEACCOUNTOPEN" class="java.sql.Timestamp"/>
	<field name="LIMITAMOUNT" class="java.math.BigDecimal"/>
	<field name="PRODUCT_CODE" class="java.lang.String"/>
	<field name="ACCOUNTREVIEWDATE" class="java.sql.Timestamp"/>
	<field name="PERIODOFLOAN" class="java.math.BigDecimal"/>
	<field name="LEDGERBALANCE" class="java.math.BigDecimal"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<variable name="LMT_AMT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LIMITAMOUNT}]]></variableExpression>
	</variable>
	<variable name="LED_BALANCE" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LEDGERBALANCE}]]></variableExpression>
	</variable>
