<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="GlBalanceReportRG" language="groovy" pageWidth="704" pageHeight="842" columnWidth="664" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f819f237-d304-4052-b023-d16a14429e37">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="90"/>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="branch_code" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ROWNUM AS SERIALNUMBER,
       ACCOUNTCODE,
       ACCOUNTNAME,
       OPENBALANCE,
       TOTALDEBIT,
       TOTALCREDIT,
       CLOSINGBALANCE,
       REMARK,
      nvl(LL,0)LL,
       nvl(CC,0)CC,
       nvl(DD,0)DD
FROM (
    SELECT
        Y.GLACCOUNT_CODE AS ACCOUNTCODE,
        INITCAP(Y.DESCRIPTION) AS ACCOUNTNAME,
        X.OPENINGBALANCE AS OPENBALANCE,

        (NVL(X.DEBITCASH,0) + NVL(X.DEBITTRANSFER,0) + NVL(X.DEBITCLEARING,0)) AS TOTALDEBIT,

        (NVL(X.CREDITCASH,0) + NVL(X.CREDITTRANSFER,0) + NVL(X.CREDITCLEARING,0)) AS TOTALCREDIT,

        (X.OPENINGBALANCE
         - (NVL(X.DEBITCASH,0) + NVL(X.DEBITTRANSFER,0) + NVL(X.DEBITCLEARING,0))
         + (NVL(X.CREDITCASH,0) + NVL(X.CREDITTRANSFER,0) + NVL(X.CREDITCLEARING,0))
        ) AS CLOSINGBALANCE,

        CASE
            WHEN (X.OPENINGBALANCE < 0 AND
                 (X.OPENINGBALANCE
                  - (NVL(X.DEBITCASH,0) + NVL(X.DEBITTRANSFER,0) + NVL(X.DEBITCLEARING,0))
                  + (NVL(X.CREDITCASH,0) + NVL(X.CREDITTRANSFER,0) + NVL(X.CREDITCLEARING,0))) > 0)
            OR
                 (X.OPENINGBALANCE > 0 AND
                 (X.OPENINGBALANCE
                  - (NVL(X.DEBITCASH,0) + NVL(X.DEBITTRANSFER,0) + NVL(X.DEBITCLEARING,0))
                  + (NVL(X.CREDITCASH,0) + NVL(X.CREDITTRANSFER,0) + NVL(X.CREDITCLEARING,0))) < 0)
            THEN '**'
        END AS REMARK,

        CASE
            WHEN Y.CODETYPE = 'LL'
            THEN (X.OPENINGBALANCE
                  - (NVL(X.DEBITCASH,0) + NVL(X.DEBITTRANSFER,0) + NVL(X.DEBITCLEARING,0))
                  + (NVL(X.CREDITCASH,0) + NVL(X.CREDITTRANSFER,0) + NVL(X.CREDITCLEARING,0)))
        END AS LL,

        CASE
            WHEN Y.CODETYPE = 'CC'
            THEN (X.OPENINGBALANCE
                  - (NVL(X.DEBITCASH,0) + NVL(X.DEBITTRANSFER,0) + NVL(X.DEBITCLEARING,0))
                  + (NVL(X.CREDITCASH,0) + NVL(X.CREDITTRANSFER,0) + NVL(X.CREDITCLEARING,0)))
        END AS CC,

        CASE
            WHEN Y.CODETYPE = 'DD'
            THEN (X.OPENINGBALANCE
                  - (NVL(X.DEBITCASH,0) + NVL(X.DEBITTRANSFER,0) + NVL(X.DEBITCLEARING,0))
                  + (NVL(X.CREDITCASH,0) + NVL(X.CREDITTRANSFER,0) + NVL(X.CREDITCLEARING,0)))
        END AS DD

    FROM BALANCE.BRANCHGLHISTORY X
    JOIN HEADOFFICE.GLACCOUNT Y
      ON X.GLACCOUNT_CODE = Y.GLACCOUNT_CODE

    WHERE X.BRANCH_CODE = $P{branch_code} -- change branch code here
      AND X.TXN_DATE = TO_DATE($P{as_on_date},'DD-MM-YYYY')  -- change date here
      AND (
            NVL(X.OPENINGBALANCE,0) <> 0 OR
            NVL(X.DEBITCASH,0) <> 0 OR
            NVL(X.DEBITTRANSFER,0) <> 0 OR
            NVL(X.DEBITCLEARING,0) <> 0 OR
            NVL(X.CREDITCASH,0) <> 0 OR
            NVL(X.CREDITTRANSFER,0) <> 0 OR
            NVL(X.CREDITCLEARING,0) <> 0
          )

    ORDER BY X.GLACCOUNT_CODE
)]]>
	</queryString>
	<field name="SERIALNUMBER" class="java.math.BigDecimal"/>
	<field name="ACCOUNTCODE" class="java.lang.String"/>
	<field name="ACCOUNTNAME" class="java.lang.String"/>
	<field name="OPENBALANCE" class="java.math.BigDecimal"/>
	<field name="TOTALDEBIT" class="java.math.BigDecimal"/>
	<field name="TOTALCREDIT" class="java.math.BigDecimal"/>
	<field name="CLOSINGBALANCE" class="java.math.BigDecimal"/>
	<field name="REMARK" class="java.lang.String"/>
	<field name="LL" class="java.math.BigDecimal"/>
	<field name="CC" class="java.math.BigDecimal"/>
	<field name="DD" class="java.math.BigDecimal"/>
	<variable name="sumofdd" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{DD}]]></variableExpression>
	</variable>
	<variable name="sumofLL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{LL}]]></variableExpression>
	</variable>
	<variable name="sumofCC" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CC}]]></variableExpression>
	</variable>
	<variable name="totalDebit" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALDEBIT}]]></variableExpression>
	</variable>
	<variable name="totalcredit" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTALCREDIT}]]></variableExpression>
	</variable>
	<variable name="variable1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{sumofLL}+$V{sumofCC}]]></variableExpression>
	</variable>
