	<queryString>
		<![CDATA[SELECT DUE_DATE, OPENING_BALANCE, PRINCIPAL_INSTALLMENT, INTEREST_INSTALLMENT, INTEREST_RATE,
			CLOSING_BALANCE, INSTALLMENT_NO, (INTEREST_INSTALLMENT + PRINCIPAL_INSTALLMENT) AS TOTAL_INSTALLMENT
			FROM ACCOUNT.ACCOUNTLOANDIARY
			WHERE ACCOUNT_CODE = $P{account_code}]]>
	</queryString>
	<field name="DUE_DATE" class="java.sql.Timestamp"/>
	<field name="OPENING_BALANCE" class="java.math.BigDecimal"/>
	<field name="PRINCIPAL_INSTALLMENT" class="java.math.BigDecimal"/>
	<field name="INTEREST_INSTALLMENT" class="java.math.BigDecimal"/>
	<field name="INTEREST_RATE" class="java.math.BigDecimal"/>
	<field name="CLOSING_BALANCE" class="java.math.BigDecimal"/>
	<field name="INSTALLMENT_NO" class="java.math.BigDecimal"/>
	<field name="TOTAL_INSTALLMENT" class="java.math.BigDecimal"/>
	<variable name="OPEN_BAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{OPENING_BALANCE}]]></variableExpression>
	</variable>
	<variable name="INT_RATE" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INTEREST_RATE}]]></variableExpression>
	</variable>
	<variable name="PRINCIPLE_INST" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{PRINCIPAL_INSTALLMENT}]]></variableExpression>
	</variable>
	<variable name="INTEREST_INST" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INTEREST_INSTALLMENT}]]></variableExpression>
	</variable>
	<variable name="TOTAL_INST" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL_INSTALLMENT}]]></variableExpression>
	</variable>
	<variable name="CLOSE_BAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CLOSING_BALANCE}]]></variableExpression>
	</variable>
