	<queryString>
		<![CDATA[SELECT rownum srno,PRODUCT_CODE,PRODUCT_NAME,all_ac,all_amt,ovd_live_Ac_no,
ovd_live_amt,exp_due_no,exp_due_amt,exp_due_no,ovd_due_ac_no,ovd_due_amt FROM
( select PRODUCT_CODE, PRODUCT_NAME, sum(ALL_NO_ACCOUNTS) all_ac,
abs (sum (ALL_AMOUNT)) all_amt, sum(LIVE_NO_ACCOUNTS) ovd_live_Ac_no,
sum(LIVE_AMOUNT) ovd_live_amt,
sum(DUE_NO_ACCOUNTS)  exp_due_no,
 sum(DUE_AMOUNT)   exp_due_amt ,
 sum(OVERDUE_NO_ACCOUNTS) ovd_due_ac_no,
 sum(OVERDUE_AMOUNT) ovd_due_amt
from  temp.rep_ovd_summ where BRANCH_CODE between $P{from_product} and $P{to_product}
AND ALL_NO_ACCOUNTS<>0
group by  PRODUCT_CODE,PRODUCT_NAME
order by  PRODUCT_CODE )]]>
	</queryString>
