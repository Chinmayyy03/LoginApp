	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
SUBSTR(ACCOUNT_CODE,5,3) PRODUCT_CODE,
FN_GET_PRODUCT_DESC (SUBSTR(ACCOUNT_CODE,5,3)) PROD,
COUNT(*),
abs (SUM(FN_GET_BALANCE_ASON ('12-DEC-25',ACCOUNT_CODE)))BAL
FROM BALANCE.ACCOUNT
WHERE
--substr(ACCOUNT_CODE,1,4) between '530' and '530'
  FN_GET_BALANCE_ASON ('12-DEC-25',ACCOUNT_CODE)<>0
GROUP BY  SUBSTR(ACCOUNT_CODE,5,3) ,FN_GET_PRODUCT_DESC
(SUBSTR(ACCOUNT_CODE,5,3))
ORDER BY 1]]>
	</queryString>
	<field name="PRODUCT_CODE" class="java.lang.String"/>
	<field name="PROD" class="java.lang.String"/>
	<field name="COUNT(*)" class="java.math.BigDecimal"/>
	<field name="BAL" class="java.math.BigDecimal"/>
	<variable name="sum count" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{COUNT(*)}]]></variableExpression>
	</variable>
	<variable name="sum bal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BAL}]]></variableExpression>
	</variable>
