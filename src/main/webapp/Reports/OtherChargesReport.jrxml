	<field name="OTHER_CHARGES" class="java.math.BigDecimal"/>
	<field name="SURCHARGE" class="java.math.BigDecimal"/>
	<field name="TOTAL" class="java.math.BigDecimal"/>
	<variable name="account_sum" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{ACCOUNT_CODE}]]></variableExpression>
	</variable>
	<variable name="Insurance_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INSURANCE}]]></variableExpression>
	</variable>
	<variable name="countcharges_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{COURT_CHARGES}]]></variableExpression>
	</variable>
	<variable name="total_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
	</variable>
