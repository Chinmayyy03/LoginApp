	<queryString>
		<![CDATA[SELECT ROWNUM AS SR_NO,
       AMOUNT_FROM,
       AMOUNT_TO,
       ACCOUNT_CODE,
       NAME,
       BALANCE,
       PRODUCT_NAME,
       BRCODE,
       SCHEM_NAME
FROM
(
    SELECT AMOUNT_FROM,
           AMOUNT_TO,
           ACCOUNT_CODE,
           fn_get_account_name(ACCOUNT_CODE) NAME,
           BALANCE,
           SUBSTR(ACCOUNT_CODE,5,3) PRODUCT_NAME,
           SUBSTR(ACCOUNT_CODE,0,7) BRCODE,
           fn_get_product_name(SUBSTR(ACCOUNT_CODE,5,3)) SCHEM_NAME

    FROM BANKDATA.SIZEWISE,
         BANKDATA.SIZEWISEAMOUNT

    WHERE BALANCE >= AMOUNT_FROM
      AND BALANCE <= AMOUNT_TO
 AND BRANCH_CODE BETWEEN '$P!{branch_code}'
                          AND '$P!{branch_code}'

    ORDER BY ACCOUNT_CODE
)
ORDER BY SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="AMOUNT_FROM" class="java.math.BigDecimal"/>
	<field name="AMOUNT_TO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="BALANCE" class="java.math.BigDecimal"/>
	<field name="PRODUCT_NAME" class="java.lang.String"/>
	<field name="BRCODE" class="java.lang.String"/>
	<field name="SCHEM_NAME" class="java.lang.String"/>
	<variable name="balance_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE}]]></variableExpression>
	</variable>
