	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT A.ACCOUNT_CODE,
SUBSTR(A.ACCOUNT_CODE,5,3) AS PRODUCT,
'1' AS P,
B.DESCRIPTION,
INITCAP(TRIM(A.NAME)) AS NAME,
to_char(A.DATEACCOUNTCLOSE,'DD-MON-YY') as CLOSE_D,
to_char(A.DATEACCOUNTOPEN,'DD-MON-YY') as OPEN_D,
LEDGERBALANCE BAL
FROM ACCOUNT.ACCOUNT A,
HEADOFFICE.PRODUCT B,
BALANCE.ACCOUNT BA
WHERE SUBSTR(A.ACCOUNT_CODE, 5, 3) = B.PRODUCT_CODE
AND A.DATEACCOUNTCLOSE BETWEEN $P{as_on_date} AND $P{to_date}
AND SUBSTR(A.ACCOUNT_CODE, 1, 4) = $P{branch_code}
AND A.ACCOUNT_CODE = BA.ACCOUNT_CODE
AND B.PRODUCT_CODE BETWEEN $P{from_product} AND $P{to_product}
ORDER BY PRODUCT, A.ACCOUNT_CODE]]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="PRODUCT" class="java.lang.String"/>
	<field name="P" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="CLOSE_D" class="java.lang.String"/>
	<field name="OPEN_D" class="java.lang.String"/>
	<field name="BAL" class="java.math.BigDecimal"/>
	<variable name="pbalance_sum" class="java.math.BigDecimal" resetType="Group" resetGroup="product code" calculation="Sum">
		<variableExpression><![CDATA[$F{BAL}]]></variableExpression>
	</variable>
	<variable name="Tbalance_sum" class="java.math.BigDecimal" resetType="Group" resetGroup="product code" calculation="Sum">
		<variableExpression><![CDATA[$F{BAL}]]></variableExpression>
	</variable>
