	<queryString>
		<![CDATA[SELECT prd, slab, noac, total
FROM (
    SELECT
        a.product_code AS prd,
        (a.amount_from || ' To ' || a.amount_to) AS slab,
        COUNT(b.account_code) AS noac,
        SUM(b.balance) AS total
    FROM
        BANKDATA.SIZEWISEAMOUNT_LOAN a,
        BANKDATA.SIZEWISE_LOAN b
    WHERE
        b.branch_code = '$P!{branch_code}'
        AND a.product_code = b.ainner
    GROUP BY
        a.product_code,
        b.ainner,
        (a.amount_from || ' To ' || a.amount_to)
)
ORDER BY prd]]>
	</queryString>
	<field name="PRD" class="java.lang.String"/>
	<field name="SLAB" class="java.lang.String"/>
	<field name="NOAC" class="java.math.BigDecimal"/>
	<field name="TOTAL" class="java.math.BigDecimal"/>
	<variable name="account_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{NOAC}]]></variableExpression>
	</variable>
	<variable name="total_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
	</variable>
