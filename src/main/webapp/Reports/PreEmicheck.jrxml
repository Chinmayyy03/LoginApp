	<parameter name="fromproductcode" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    AL.ACCOUNT_CODE,
    SUBSTR(AL.ACCOUNT_CODE, 5, 3) AS PRODUCT_CODE,
    TRIM(AA.NAME) AS NAME,
    TO_CHAR(AA.DATEACCOUNTOPEN, 'DD-MON-YY') AS A,
    AL.MORATORIUMPEROIDMONTH,
    AL.PERIODOFLOAN,
    TO_CHAR(AL.ACCOUNTREVIEWDATE, 'DD-MON-YY') AS B,
    BA.LEDGERBALANCE,
    AL.LIMITAMOUNT,
    AL.DISBURESED_AMOUNT,
    AL.DRAWINGPOWER,
    AL.INSTALLMENTTYPE_ID,
    CASE
        WHEN (
            SELECT
                AI.INTERESTRATE
            FROM
                ACCOUNT.ACCOUNTINTERESTLOANRATES AI
            WHERE
                AI.DATEOFAPPLICATION = AA.DATEACCOUNTOPEN
                AND AI.ACCOUNT_CODE = AA.ACCOUNT_CODE
        ) IS NULL
        THEN 0
        ELSE (
            SELECT
                AI.INTERESTRATE
            FROM
                ACCOUNT.ACCOUNTINTERESTLOANRATES AI
            WHERE
                AI.DATEOFAPPLICATION = AA.DATEACCOUNTOPEN
                AND AI.ACCOUNT_CODE = AA.ACCOUNT_CODE
        )
    END AS INTERESTRATE
FROM
    ACCOUNT.ACCOUNTLOAN AL,
    BALANCE.ACCOUNT BA,
    ACCOUNT.ACCOUNT AA
WHERE
    AL.ACCOUNT_CODE = AA.ACCOUNT_CODE
    AND AL.ACCOUNT_CODE = BA.ACCOUNT_CODE
    AND AA.ACCOUNT_STATUS = 'L'
    AND AA.DATEACCOUNTCLOSE IS NULL
    AND AL.ACCOUNT_CODE LIKE $P{fromproductcode}
    AND AL.INSTALLMENTTYPE_ID = $P{installment_id}
ORDER BY
    AL.ACCOUNT_CODE]]>
	</queryString>
