	<field name="PRODUCT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="A" class="java.lang.String"/>
	<field name="MORATORIUMPEROIDMONTH" class="java.math.BigDecimal"/>
	<field name="PERIODOFLOAN" class="java.math.BigDecimal"/>
	<field name="B" class="java.lang.String"/>
	<field name="LEDGERBALANCE" class="java.math.BigDecimal"/>
	<field name="LIMITAMOUNT" class="java.math.BigDecimal"/>
	<field name="DISBURESED_AMOUNT" class="java.math.BigDecimal"/>
	<field name="DRAWINGPOWER" class="java.math.BigDecimal"/>
	<field name="INSTALLMENTTYPE_ID" class="java.math.BigDecimal"/>
	<field name="INTERESTRATE" class="java.math.BigDecimal"/>
