	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ROWNUM AS SRNO,
    A.*
FROM
(
    SELECT
        B.ACCOUNT_CODE,
        SUBSTR(B.ACCOUNT_CODE,5,3) AS PRODUCT_CODE,
        K.DESCRIPTION,
        B.AMOUNTINMATUREDDEPOSIT,
        INITCAP(A.NAME) AS NAME,
        B.INTERESTRATE,
        B.DEPOSITAMOUNT,
        B.UNITOFPERIOD,
        B.PERIODOFDEPOSIT,
        TO_CHAR(B.MATURITYDATE,'DD/MM/YYYY') AS MATURITY_DATE,
        B.PROCESSFOR_MATURITY,
        TO_CHAR(A.DATEACCOUNTOPEN,'DD/MM/YYYY') AS OPEN_DATE,
        C.LEDGERBALANCE,

        (
            SELECT MAX(TXN_DATE)
            FROM TRANSACTION.DAILYTXN
            WHERE ACCOUNT_CODE = B.ACCOUNT_CODE
            AND UPPER(PARTICULAR) NOT LIKE '%INTEREST%'
            AND SUBSTR(TRANSACTIONINDICATOR_CODE,3,2) = 'CR'
        ) AS INT_DATE

    FROM
        ACCOUNT.ACCOUNTINVEST B,
        ACCOUNT.ACCOUNT A,
        BALANCE.ACCOUNT C,
        HEADOFFICE.PRODUCT K

    WHERE
        B.ACCOUNT_CODE = A.ACCOUNT_CODE
        AND B.ACCOUNT_CODE = C.ACCOUNT_CODE
        AND SUBSTR(B.ACCOUNT_CODE,5,3) = K.PRODUCT_CODE

        AND B.ACCOUNT_CODE LIKE $P{finalProductCode}

       -- AND A.DATEACCOUNTCLOSE IS NULL

        AND B.MATURITYDATE <= $P{as_on_date}

    ORDER BY B.ACCOUNT_CODE
) A]]>
	</queryString>
