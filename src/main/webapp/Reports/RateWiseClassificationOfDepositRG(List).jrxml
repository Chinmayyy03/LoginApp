	<parameter name="report_title" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="as_on_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<parameter name="to_branch" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    ROW_NUMBER() OVER (PARTITION BY RATE_INT ORDER BY RATE_INT) AS ROWNO,
    ACCOUNT_CODE,
    AC_NAME,
    RATE_INT,
    TRAN_AMOUNT,
    PRODUCT,
    DESCRIPTION
FROM (
    SELECT
        R.ACCOUNT_CODE AS ACCOUNT_CODE,
        A.NAME AS AC_NAME,
        R.INTEREST_RATE AS RATE_INT,
        R.BALANCE AS TRAN_AMOUNT,
        SUBSTR(A.ACCOUNT_CODE, 5, 3) AS PRODUCT,
        B.DESCRIPTION AS DESCRIPTION
    FROM
        BANKDATA.RATEWISEDEPOSITCLASS R,
        ACCOUNT.ACCOUNT A,
        HEADOFFICE.PRODUCT B
    WHERE
        R.ACCOUNT_CODE = A.ACCOUNT_CODE
        AND SUBSTR(R.ACCOUNT_CODE, 5, 3) = B.PRODUCT_CODE
        AND BRANCH_CODE BETWEEN $P{branch_code} AND $P{to_branch}
        AND BALANCE <> 0
    ORDER BY
        R.INTEREST_RATE
)
WHERE
    RATE_INT > 0
ORDER BY
    RATE_INT]]>
	</queryString>
	<field name="ROWNO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="AC_NAME" class="java.lang.String"/>
	<field name="RATE_INT" class="java.math.BigDecimal"/>
	<field name="TRAN_AMOUNT" class="java.math.BigDecimal"/>
	<field name="PRODUCT" class="java.lang.String"/>
	<field name="DESCRIPTION" class="java.lang.String"/>
	<variable name="balanceinterst_sum" class="java.math.BigDecimal" resetType="Group" resetGroup="Interst rate" calculation="Sum">
