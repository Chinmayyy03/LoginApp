	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ROWNUM as SR_NO, AMOUNT_FROM, AMOUNT_TO, cust_code, CUST_NAME, BALANCE_AMT
FROM (
    SELECT AMOUNT_FROM, AMOUNT_TO, cust_code, CUST_NAME, SUM(BALANCE_AMT) BALANCE_AMT
    FROM (
        SELECT S.AMOUNT_FROM AMOUNT_FROM, S.AMOUNT_TO AMOUNT_TO,
               C.CUSTOMER_ID CUST_CODE, C.NAME CUST_NAME,
               A.BALANCE BALANCE_AMT
        FROM bankdata.SIZEWISE A,
             BANKDATA.SIZEWISEAMOUNT S,
             CUSTOMER.CUSTOMER C,
             ACCOUNT.ACCOUNT T
        WHERE A.ACCOUNT_CODE = T.ACCOUNT_CODE
          AND T.CUSTOMER_ID = C.CUSTOMER_ID
         AND A.balance >= S.amount_from
         AND A.balance <= S.amount_to
          AND A.branch_code BETWEEN '$P!{branch_code}'
          AND '$P!{branch_code}'
    ) TEMP
    GROUP BY cust_code, AMOUNT_FROM, AMOUNT_TO, CUST_NAME
) TEMP1
ORDER BY SR_NO]]>
	</queryString>
	<field name="SR_NO" class="java.math.BigDecimal"/>
	<field name="AMOUNT_FROM" class="java.math.BigDecimal"/>
	<field name="AMOUNT_TO" class="java.math.BigDecimal"/>
	<field name="CUST_CODE" class="java.lang.String"/>
	<field name="CUST_NAME" class="java.lang.String"/>
	<field name="BALANCE_AMT" class="java.math.BigDecimal"/>
	<variable name="balance_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{BALANCE_AMT}]]></variableExpression>
	</variable>
