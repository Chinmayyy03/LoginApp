<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DepositLoanSpreadRG(summary)" language="groovy" pageWidth="569" pageHeight="842" columnWidth="529" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="282160c9-1c98-4324-81f6-1d30e8614050">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<queryString>
		<![CDATA[SELECT
    D_BRANCH_CODE,
    DECODE(TRIM(D_SEQ_NO), '1001', '', '9999', '', TRIM(D_SEQ_NO)) AS D_SEQ_NO,
    D_DESCRIPTION,
    D_REP_CHAR,
    D_BALANCE,
    L_BRANCH_CODE,
    DECODE(TRIM(L_SEQ_NO), '1001', '', TRIM(L_SEQ_NO)) AS L_SEQ_NO,
    L_DESCRIPTION,
    L_REP_CHAR,
    L_BALANCE
FROM
    (
        SELECT
            BRANCH_CODE AS D_BRANCH_CODE,
            SEQ_NO AS D_SEQ_NO,
            DESCRIPTION AS D_DESCRIPTION,
            REP_CHAR AS D_REP_CHAR,
            BALANCE AS D_BALANCE
        FROM
            BANKDATA.FP_TD_TL_AVG
        WHERE
            REP_CHAR = 'D'
            AND SEQ_NO = 1001

        UNION

        SELECT
            BRANCH_CODE AS D_BRANCH_CODE,
            SEQ_NO AS D_SEQ_NO,
            DESCRIPTION AS D_DESCRIPTION,
            REP_CHAR AS D_REP_CHAR,
            BALANCE AS D_BALANCE
        FROM
            BANKDATA.FP_TD_TL_AVG
        WHERE
            REP_CHAR = 'Z'
            AND SEQ_NO = 9999
    ),
    (
        SELECT
            BRANCH_CODE AS L_BRANCH_CODE,
            SEQ_NO AS L_SEQ_NO,
            DESCRIPTION AS L_DESCRIPTION,
            REP_CHAR AS L_REP_CHAR,
            BALANCE AS L_BALANCE
        FROM
            BANKDATA.FP_TD_TL_AVG
        WHERE
            REP_CHAR = 'L'
            AND SEQ_NO = 1001
    )
ORDER BY
    D_REP_CHAR]]>
	</queryString>
	<field name="D_BRANCH_CODE" class="java.lang.String"/>
	<field name="D_SEQ_NO" class="java.lang.String"/>
	<field name="D_DESCRIPTION" class="java.lang.String"/>
