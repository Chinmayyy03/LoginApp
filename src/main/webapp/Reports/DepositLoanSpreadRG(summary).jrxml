	<field name="D_BALANCE" class="java.math.BigDecimal"/>
	<field name="L_BRANCH_CODE" class="java.lang.String"/>
	<field name="L_SEQ_NO" class="java.lang.String"/>
	<field name="L_DESCRIPTION" class="java.lang.String"/>
