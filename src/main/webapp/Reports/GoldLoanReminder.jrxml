	<queryString>
		<![CDATA[SELECT L.ACCOUNT_CODE, A.NAME, C.ADDRESS1 || ' ' || C.ADDRESS2 || ' ' || C.ADDRESS3 AS ADDRESS,
                    L.ACCOUNTREVIEWDATE, B.LEDGERBALANCE
                    FROM ACCOUNT.ACCOUNT A, ACCOUNT.ACCOUNTLOAN L, BALANCE.ACCOUNT B, CUSTOMER.CUSTOMER C
                    WHERE SUBSTR(L.ACCOUNT_CODE, 1,4) =  $P{branch_code}
                    AND SUBSTR(L.ACCOUNT_CODE, 5,3) = $P{product_code}
                    AND L.ACCOUNTREVIEWDATE BETWEEN $P{form_date} AND $P{to_date}
                    AND L.ACCOUNT_CODE = A.ACCOUNT_CODE
                    AND L.ACCOUNT_CODE = B.ACCOUNT_CODE
                    AND A.CUSTOMER_ID = C.CUSTOMER_ID
                    AND A.DATEACCOUNTCLOSE IS NULL
                    ORDER BY L.ACCOUNT_CODE]]>
	</queryString>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="ADDRESS" class="java.lang.String"/>
	<field name="ACCOUNTREVIEWDATE" class="java.sql.Timestamp"/>
	<field name="LEDGERBALANCE" class="java.math.BigDecimal"/>
