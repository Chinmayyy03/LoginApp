	</parameter>
	<parameter name="to_date" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_amount" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_amount" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="from_product" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="to_product" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["./"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT SR_NUMBER ,
       ACCOUNT_CODE,
       NAME,
       TO_CHAR(DATEACCOUNTOPEN,'DD/MM/YYYY') AS DACCOUNTOPEN,
       SANCTIONAMOUNT,
       TO_CHAR(DATEACCOUNTCLOSE,'DD/MM/YYYY') AS DACCOUNTCLOSE,
       AVAILABLEBALANCE
FROM
(
    SELECT ROWNUM SR_NUMBER,
           L.ACCOUNT_CODE ACCOUNT_CODE,
           A.NAME NAME,
           L.LIMITAMOUNT LIMITAMOUNT,
           L.SANCTIONAMOUNT SANCTIONAMOUNT,
           A.DATEACCOUNTOPEN DATEACCOUNTOPEN,
           A.ACCOUNT_STATUS ACCOUNT_STATUS,
           A.DATEACCOUNTCLOSE DATEACCOUNTCLOSE,
           FN_GET_BALANCE_ASON(
               TO_DATE($P{to_date},'DD/MM/YYYY'),
               A.ACCOUNT_CODE
           ) AVAILABLEBALANCE
    FROM ACCOUNT.ACCOUNT A,
         ACCOUNT.ACCOUNTLOAN L
    WHERE A.ACCOUNT_CODE = L.ACCOUNT_CODE



 AND L.SANCTIONAMOUNT BETWEEN $P{from_amount} AND $P{to_amount}
   AND SUBSTR(L.ACCOUNT_CODE,1,4)= $P{branch_code}
    AND SUBSTR(L.ACCOUNT_CODE,5,3) BETWEEN $P{from_product} AND $P{to_product}
      AND A.DATEACCOUNTOPEN BETWEEN TO_DATE($P{from_date},'DD/MM/YYYY')
                             AND TO_DATE($P{to_date},'DD/MM/YYYY')
      AND FN_GET_BALANCE_ASON(
             TO_DATE($P{to_date},'DD/MM/YYYY'),
             A.ACCOUNT_CODE
       ) <> 0
   ORDER BY A.DATEACCOUNTOPEN
)ORDER BY SR_NUMBER]]>
	</queryString>
	<field name="SR_NUMBER" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="DACCOUNTOPEN" class="java.lang.String"/>
	<field name="SANCTIONAMOUNT" class="java.math.BigDecimal"/>
	<field name="DACCOUNTCLOSE" class="java.lang.String"/>
	<field name="AVAILABLEBALANCE" class="java.math.BigDecimal"/>
	<variable name="Sanction_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{SANCTIONAMOUNT}]]></variableExpression>
	</variable>
	<variable name="Balance_sum" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{AVAILABLEBALANCE}]]></variableExpression>
	</variable>
