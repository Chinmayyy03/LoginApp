	<queryString>
		<![CDATA[select ROWNUM AS SRNO,a.account_code , a.name , to_char(A.DATEACCOUNTOPEN,'dd/mm/yyyy') ACCOUNTOPEN_D,
		   to_char(P.MATURITYDATE,'dd/mm/yyyy')  MATURITY_D, P.INSTALLMENTAMOUNT ,
		   P.UNITOFPERIOD ,P.PERIODOFDEPOSIT ,P.INTERESTRATE ,
		   to_char(A.DATEACCOUNTCLOSE,'DD/MM/YYYY') AS C
		   from account.account a ,
		   account.accountpigmy p where A.ACCOUNT_CODE=P.ACCOUNT_CODE
		   and substr(a.account_code,1,4)=$P{branch_code}
		   and P.MATURITYDATE between $P{from_date}
		   and $P{to_date}]]>
	</queryString>
	<field name="SRNO" class="java.math.BigDecimal"/>
	<field name="ACCOUNT_CODE" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="ACCOUNTOPEN_D" class="java.lang.String"/>
	<field name="MATURITY_D" class="java.lang.String"/>
	<field name="INSTALLMENTAMOUNT" class="java.math.BigDecimal"/>
	<field name="UNITOFPERIOD" class="java.lang.String"/>
	<field name="PERIODOFDEPOSIT" class="java.math.BigDecimal"/>
	<field name="INTERESTRATE" class="java.math.BigDecimal"/>
	<field name="C" class="java.lang.String"/>
	<variable name="INSTALL_AMOUNT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INSTALLMENTAMOUNT}]]></variableExpression>
	</variable>
