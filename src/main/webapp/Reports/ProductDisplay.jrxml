	<queryString>
		<![CDATA[SELECT ROWNUM AS SR_NO,
       PRODUCT_DATE,
       NORMAL_PRODUCT,
       PENAL_PRODUCT,
       OVERDUE_PRODUCT
FROM temp.dailyproducts
WHERE ACCOUNT_CODE = $P{account_code}]]>
	</queryString>
